# ============================================================
# PiForum — Cloudflare Pages Environment Variables
# ============================================================
# Copy to .env.cloudflare and edit values.
# Non-secret vars go in wrangler.toml [vars].
# Secret vars are set via: npx wrangler pages secret put NAME
# ============================================================

# ---- Site ----
NEXT_PUBLIC_SITE_URL=https://piforum.eu.org
NEXT_PUBLIC_SITE_NAME=PiForum
NEXTAUTH_URL=https://piforum.eu.org

# ---- Secrets (set with `wrangler pages secret put`) ----
# NEXTAUTH_SECRET                       (generate: openssl rand -base64 32)
# ZAI_API_KEY
# SMTP_HOST / SMTP_PORT / SMTP_USER / SMTP_PASSWORD / SMTP_FROM
# WHATSAPP_TOKEN / WHATSAPP_PHONE_NUMBER_ID / WHATSAPP_VERIFY_TOKEN
# TELEGRAM_BOT_TOKEN

# ---- D1 binding (configured in wrangler.toml, not env) ----
# The `DB` binding exposes D1 to your code via getRequestContext().env.DB

# ---- R2 binding (configured in wrangler.toml) ----
# The `UPLOADS` binding exposes R2 for file uploads
