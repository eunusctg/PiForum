# ============================================================
# PiForum — Serv00.com Apache Reverse Proxy Configuration
# ============================================================
# Place this file at: ~/domains/piforum.eu.org/public_html/.htaccess
# (and duplicate it for piforum.eu.cc)
#
# This forwards all web traffic from Apache to your Node.js app
# running on port 3000 (or whichever PORT you set in .env).
# ============================================================

<IfModule mod_rewrite.c>
  RewriteEngine On

  # ---- Force HTTPS ----
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # ---- Exclude real files/dirs (static assets you may upload directly) ----
  RewriteCond %{REQUEST_URI} !^/\.well-known/
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # ---- Reverse-proxy everything to the Node.js server ----
  # Change 3000 to match the PORT in your .env on serv00
  RewriteRule ^(.*)$ http://127.0.0.1:3000/$1 [P,L]
</IfModule>

# ============================================================
# Pass through headers so Next.js sees real client info
# ============================================================
<IfModule mod_proxy.c>
  ProxyPreserveHost On
  ProxyRequests Off
  RequestHeader set X-Forwarded-Proto "https"
  RequestHeader set X-Forwarded-Host "%{HTTP_HOST}e"
</IfModule>

# ============================================================
# Security + caching headers
# ============================================================
<IfModule mod_headers.c>
  # Don't cache the HTML (Next.js handles caching of assets itself)
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>

  # Cache immutable Next.js chunks aggressively
  <FilesMatch "\.(js|css|woff2|png|jpg|jpeg|gif|svg|ico|webp)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Basic security headers
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ============================================================
# Gzip compression
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>
