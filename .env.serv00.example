# ============================================================
# PiForum — Serv00.com Environment Variables
# ============================================================
# Copy to .env on serv00 and edit values.
# File path: ~/piforum/.env
# ============================================================

# ---- Database (SQLite file) ----
# Use an ABSOLUTE path on serv00. Replace YOUR_USERNAME with your serv00 login.
DATABASE_URL=file:/home/YOUR_USERNAME/piforum/db/custom.db

# ---- Server ----
NODE_ENV=production
PORT=3000
HOSTNAME=127.0.0.1

# ---- NextAuth (auth secret) ----
# Generate a new one with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING
NEXTAUTH_URL=https://piforum.eu.org

# ---- Public site URL (used for SEO, OG tags, sitemap) ----
NEXT_PUBLIC_SITE_URL=https://piforum.eu.org
NEXT_PUBLIC_SITE_NAME=PiForum

# ---- (Optional) Email SMTP — for Email OTP / verification ----
# Leave blank to disable email features. Free tier: SendGrid (100/day), Brevo (300/day).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@piforum.eu.org

# ---- (Optional) TOTP 2FA ----
# No env vars needed — TOTP secrets are stored per-user in the database.

# ---- (Optional) WhatsApp Cloud API OTP ----
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# ---- (Optional) Telegram Bot OTP ----
TELEGRAM_BOT_TOKEN=

# ---- (Optional) Z.AI SDK (for built-in AI features if used) ----
ZAI_API_KEY=
